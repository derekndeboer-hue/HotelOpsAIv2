# Web (Vite) Environment Variables
# Copy this to .env and fill in values.
# All VITE_* vars are bundled into the client — never put real secrets here.

# API base URL — the Express API server this web app talks to
VITE_API_BASE_URL=http://localhost:3001/api

# Firebase / Firestore — powers real-time room board, alerts, and notifications.
# Leave blank for local dev; the app gracefully degrades to REST polling when unset.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
