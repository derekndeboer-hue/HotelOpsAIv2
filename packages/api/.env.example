# Local Development Environment Variables
# Copy this to .env and fill in values

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://hotel_api_user:localdev123@localhost:5432/hotel_ops

# JWT Secrets (generate your own for production)
JWT_SECRET=local-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-in-production

# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# GCP (optional for local dev — app uses local fallbacks when missing)
# GCP_PROJECT_ID=your-gcp-project
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
